{
  "name": "web",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/run-with-watchdog.mjs --idle-ms=180000 --stagnation-ms=480000 --max-ms=1800000 -- corepack pnpm run build:raw",
    "build:raw": "NODE_OPTIONS='--no-deprecation --max-old-space-size=6144' next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "NODE_OPTIONS='--no-deprecation --max-old-space-size=3072' next dev",
    "dev:prod": "NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "NODE_OPTIONS='--no-deprecation --max-old-space-size=4096' next start",
    "typecheck": "NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "corepack pnpm run build && node ./scripts/run-with-watchdog.mjs --idle-ms=120000 --stagnation-ms=180000 --max-ms=900000 -- sh -lc 'E2E_TEST_SECRET=local-e2e-secret NODE_OPTIONS=\"--no-deprecation --max-old-space-size=3072 --import=tsx/esm\" corepack pnpm exec playwright test --config=playwright.config.ts --reporter=line'",
    "test:int": "node ./scripts/run-with-watchdog.mjs --idle-ms=90000 --stagnation-ms=240000 --max-ms=900000 -- corepack pnpm run test:int:raw",
    "test:int:raw": "NODE_OPTIONS='--no-deprecation --max-old-space-size=1024' vitest run --config ./vitest.config.mts",
    "vk:import": "tsx scripts/vk-import.ts",
    "yadisk:sync": "tsx scripts/yadisk-sync-media.ts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.75.0",
    "@payloadcms/db-postgres": "3.75.0",
    "@payloadcms/live-preview-react": "3.75.0",
    "@payloadcms/next": "3.75.0",
    "@payloadcms/plugin-form-builder": "3.75.0",
    "@payloadcms/plugin-nested-docs": "3.75.0",
    "@payloadcms/plugin-redirects": "3.75.0",
    "@payloadcms/plugin-search": "3.75.0",
    "@payloadcms/plugin-seo": "3.75.0",
    "@payloadcms/richtext-lexical": "3.75.0",
    "@payloadcms/translations": "^3.82.1",
    "@payloadcms/ui": "3.75.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "15.4.11",
    "next-sitemap": "^4.2.3",
    "payload": "3.75.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "jsdom": "28.0.0",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
