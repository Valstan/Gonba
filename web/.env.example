# PostgreSQL connection
DATABASE_URL=postgresql://127.0.0.1:5432/gonba

# Payload auth secret (encrypt JWT tokens)
PAYLOAD_SECRET=generate_a_random_secret_here

# Public server URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# For production set both to your public domain, e.g.:
# NEXT_PUBLIC_SERVER_URL=https://yourdomain.ru
# PAYLOAD_PUBLIC_SERVER_URL=https://yourdomain.ru

# Secret used to authenticate cron jobs
CRON_SECRET=generate_a_cron_secret_here

# Secret used to validate preview requests
PREVIEW_SECRET=generate_a_preview_secret_here

# Yandex Disk integration
YANDEX_DISK_TOKEN=your_yandex_oauth_token
YANDEX_DISK_BASE_PATH=/gonba
YANDEX_DISK_MEDIA_PATH=/gonba/media

# VK import configuration
VK_GROUP_POST_LIMIT=50
VK_IMPORT_DELAY_MS=700
VK_IMPORT_QUEUE_ONLY=1
VK_IMPORT_AUTO_PUBLISH=0
VK_IMPORT_DRY_RUN=0

# VK tokens for specific groups (add as needed)
# VK_TOKEN_VALSTAN=vk1.a.xxx
# VK_TOKEN_VITA=vk1.a.xxx
# Or generic pattern: VK_TOKEN_{groupId} / VK_TOKEN_GROUP_{groupId}
