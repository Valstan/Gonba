# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# For production set both to your public domain, e.g.:
# NEXT_PUBLIC_SERVER_URL=https://xn--80abf4be9f.xn--p1ai
# PAYLOAD_PUBLIC_SERVER_URL=https://xn--80abf4be9f.xn--p1ai

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Optional VK import source configuration (add only groups you want to import)
# Tuning controls to avoid heavy API usage
VK_GROUP_POST_LIMIT=50
VK_IMPORT_DELAY_MS=350
VK_IMPORT_QUEUE_ONLY=1
VK_IMPORT_AUTO_PUBLISH=0
VK_IMPORT_DRY_RUN=0
# VK_GROUP_ID_KONNYY_MALMYZH=
# VK_TOKEN_KONNYY_MALMYZH=
# VK_GROUP_ID_SADOVAYA_FEYA=
# VK_TOKEN_SADOVAYA_FEYA=
