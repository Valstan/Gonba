{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull --ff-only*)",
      "Bash(git push -u origin *)",
      "Bash(git push origin *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh run watch*)",
      "Bash(corepack pnpm -C web run typecheck*)",
      "Bash(corepack pnpm -C web run lint*)",
      "Bash(corepack pnpm -C web run build:raw*)",
      "Bash(corepack pnpm -C web run test*)",
      "Bash(pnpm -C web run typecheck*)",
      "Bash(pnpm -C web run lint*)",
      "Bash(pnpm -C web run build:raw*)",
      "Bash(pnpm -C web run test*)"
    ],
    "deny": [
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push --force origin main*)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git push -f origin main*)",
      "Bash(gh workflow run deploy-prod*)",
      "Bash(gh workflow run deploy*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/git_sync_check.sh\" --warn"
          }
        ]
      }
    ]
  }
}
