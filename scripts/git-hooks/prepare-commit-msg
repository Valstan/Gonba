#!/usr/bin/env bash
# prepare-commit-msg — мягкое напоминание про DEVELOPMENT_LOG.md.
#
# Срабатывает при каждом коммите. Если первая строка сообщения начинается
# с feat:/fix:/refactor: и в staged-изменениях НЕТ docs/DEVELOPMENT_LOG.md —
# выводит жёлтое предупреждение в stderr. НЕ блокирует коммит.
#
# Установка: bash scripts/install-git-hooks.sh

set -u

COMMIT_MSG_FILE="${1:-}"
COMMIT_SOURCE="${2:-}"

# Пропускаем технические коммиты — там не нужно обновлять лог
case "${COMMIT_SOURCE}" in
  merge|squash|commit)
    exit 0
    ;;
esac

# Если файла нет или это пустой шаблон — пропускаем
[ -f "${COMMIT_MSG_FILE}" ] || exit 0

# Первая непустая строка, не комментарий
SUBJECT=$(grep -v '^#' "${COMMIT_MSG_FILE}" | grep -v '^$' | head -1 || true)
[ -n "${SUBJECT}" ] || exit 0

# Триггеримся только на feat:/fix:/refactor: (включая scope: feat(api):)
case "${SUBJECT}" in
  feat:*|feat\(*|fix:*|fix\(*|refactor:*|refactor\(*)
    ;;
  *)
    exit 0
    ;;
esac

# Список staged-файлов (для prepare-commit-msg уже доступны)
STAGED=$(git diff --cached --name-only 2>/dev/null || true)

# Если DEVELOPMENT_LOG.md в staged — всё ок
if echo "${STAGED}" | grep -qE '^docs/DEVELOPMENT_LOG\.md$'; then
  exit 0
fi

# Если такого файла вообще нет в репо — не напоминаем (новый проект)
if [ ! -f "docs/DEVELOPMENT_LOG.md" ]; then
  exit 0
fi

# Жёлтое предупреждение в stderr — git его покажет
YELLOW='\033[33m'
BOLD='\033[1m'
RESET='\033[0m'

# Если терминал не tty — без цвета
if [ ! -t 2 ]; then
  YELLOW=""
  BOLD=""
  RESET=""
fi

printf "${YELLOW}${BOLD}⚠  Напоминание:${RESET}${YELLOW} коммит \"${SUBJECT}\" — значимое изменение,\n" >&2
printf "   но docs/DEVELOPMENT_LOG.md не в staged. Обнови лог перед релизом\n" >&2
printf "   (новый блок сверху, в дату сегодняшней сессии).${RESET}\n" >&2
printf "   Коммит НЕ заблокирован — пропускаем дальше.\n" >&2

exit 0
