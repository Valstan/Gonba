# Claude Code working directory
# Игнорируем всё, кроме того что должно жить в репо вместе с проектом:
# - .claude/commands/    — slash-команды (/start, /reliz, /check, ...)
# - .claude/agents/      — кастомные субагенты
# - .claude/settings.json — SessionStart-хук git_sync_check (pool #010), общий для всех машин
# Остальное (worktrees, локальная сессия, launch.json конкретного компа) — локально.
.claude/*
!.claude/commands/
!.claude/agents/
!.claude/settings.json

# Dependencies
node_modules/
pnpm-lock.yaml

# Build outputs
build/
dist/
.next/
.vercel/

# TypeScript incremental build cache
*.tsbuildinfo

# Env files
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Payload media
public/media/

# Payload generated files
web/src/payload-types.ts
web/src/app/(payload)/admin/importMap.js

# Temporary / working files
.tmp/
*.tmp

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# IDE
.idea/
*.swp
*.swo
*~
*.code-workspace

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS thumbnails
thumbnails/

# Data dumps / local exports (VK exports, personal photos in docs)
docs/vk_export_*.txt
docs/photo_*.jpg
docs/Описание*.txt

# Local DB backups
*.dump
